{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/welcome", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/plan", "destination": "/index.html" },
    { "source": "/lesson", "destination": "/index.html" },
    { "source": "/my-plans", "destination": "/index.html" },
    { "source": "/themes", "destination": "/index.html" },
    { "source": "/profile", "destination": "/index.html" },
    { "source": "/new-plan", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "no-referrer-when-downgrade" }
      ]
    }
  ]
}
